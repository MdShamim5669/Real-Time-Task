{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A single task item in the collaborative board",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The task title" },
        "description": { "type": "string", "description": "Details about the task" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "done"], "description": "Current status of the task" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Task priority level" },
        "dueDate": { "type": "string", "description": "Optional due date as a string" },
        "ownerId": { "type": "string", "description": "UID of the creator" },
        "ownerEmail": { "type": "string", "description": "Email of the creator" },
        "assigneeId": { "type": "string", "description": "UID of the user assigned to this task" },
        "assigneeEmail": { "type": "string", "description": "Email of the assigned user" },
        "createdAt": { "type": "string", "description": "Server timestamp of creation" },
        "updatedAt": { "type": "string", "description": "Server timestamp of last update" }
      },
      "required": ["title", "status", "priority", "ownerId", "ownerEmail", "createdAt", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment left by a team member on a task",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The text content of the comment" },
        "authorId": { "type": "string", "description": "UID of the comment author" },
        "authorEmail": { "type": "string", "description": "Email of the comment author" },
        "createdAt": { "type": "string", "description": "Server timestamp of creation" }
      },
      "required": ["text", "authorId", "authorEmail", "createdAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Root collection containing all tasks"
    },
    "/tasks/{taskId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Subcollection of comments for a specific task"
    }
  }
}
